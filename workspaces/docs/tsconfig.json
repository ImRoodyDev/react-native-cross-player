{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "baseUrl": ".",
    "typeRoots": [
      "../../node_modules/@types",
      "./types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "react-native-cross-player": [
        "../package/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "types/**/*.d.ts",
    ".expo/types/**/*.ts"
  ]
}
