{
	"name": "react-native-cross-player",
	"version": "1.0.0",
	"description": "React Native Video Player Wrapper with support for HLS, Subtitles and Proxy across Web, Android, iOS",
	"scripts": {
		"clean": "rimraf dist",
		"test": "jest",
		"lint": "eslint \"src/**/*.{js,ts,tsx}\"",
		"lint:fix": "eslint \"src/**/*.{js,ts,tsx}\" --fix",
		"build": "npm run clean && bob build && npm run copy:css",
		"build:local": "npm run clean && bob build && npm run copy:css && npm pack",
		"copy:css": "powershell -Command \"Copy-Item -Path 'src/css' -Destination 'dist/css' -Recurse -Force\"",
		"publish": "npm publish --access public"
	},
	"react-native": "src/index.ts",
	"source": "./src/index.ts",
	"main": "./dist/module/index.js",
	"module": "./dist/module/index.js",
	"types": "./dist/typescript/src/index.d.ts",
	"styles": "./dist/css/styles.css",
	"exports": {
		".": {
			"types": "./dist/typescript/src/index.d.ts",
			"import": "./dist/module/index.js",
			"require": "./dist/module/index.js",
			"react-native": "./src/index.ts",
			"styles": "./dist/css/styles.css"
		},
		"./styles": "./dist/css/styles.css",
		"./styles.css": "./dist/css/styles.css"
	},
	"files": [
		"dist",
		"css/",
		"src/",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"API.md",
		"package.json"
	],
	"keywords": [
		"react-native",
		"ios",
		"android",
		"web",
		"video",
		"player",
		"hls",
		"subtitles",
		"proxy"
	],
	"author": "ImRoodyDev <> (https://github.com/imroodydev)",
	"license": "MIT",
	"homepage": "https://github.com/imroodydev/react-native-cross-player#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/imroodydev/react-native-cross-player.git"
	},
	"bugs": {
		"url": "https://github.com/imroodydev/react-native-cross-player/issues"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"dependencies": {
		"@types/node": "^25.1.0",
		"clsx": "^2.1.1",
		"hls.js": "^1.6.15",
		"m3u8-parser": "^7.2.0",
		"p-limit": "^7.0.0",
		"react-native-cross-elements": "file:../native-cross-elements/react-native-cross-elements-1.0.0.tgz"
	},
	"peerDependencies": {
		"nativewind": ">=4",
		"react": "*",
		"react-native": "*",
		"react-native-awesome-slider": ">=2",
		"react-native-blob-util": "^0.24.6",
		"react-native-gesture-handler": ">=2",
		"react-native-orientation-locker": ">=1.5.0",
		"react-native-reanimated": ">=3",
		"react-native-safe-area-context": ">=4",
		"react-native-svg": "*",
		"react-native-system-navigation-bar": ">=2",
		"react-native-video": "^6.0.0",
		"react-native-worklets": ">=0.6.0",
		"tailwindcss": ">=3"
	},
	"peerDependenciesMeta": {
		"react-native-worklets": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/m3u8-parser": "^7.2.6",
		"@types/react": "19.2.2",
		"jest": "^30.2.0",
		"react": "19.2.3",
		"react-native": "0.83.1",
		"react-native-builder-bob": "^0.40.17",
		"rimraf": "^5.0.10",
		"typescript": "5.8.3"
	},
	"react-native-builder-bob": {
		"source": "src",
		"output": "dist",
		"targets": [
			"module",
			"typescript"
		]
	}
}
